# LLM
OPENAI_API_KEY=sk-...

# LangSmith
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=intelligent-parking-chatbot

# PostgreSQL (matches docker-compose.yml defaults)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=parking
POSTGRES_USER=parking
POSTGRES_PASSWORD=parking

# Weaviate (matches docker-compose.yml defaults)
WEAVIATE_URL=http://localhost:8080
